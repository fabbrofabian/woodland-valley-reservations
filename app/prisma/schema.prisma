generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PickupDay {
  id              Int           @id @default(autoincrement())
  pickupDate      DateTime
  totalChickens   Int
  slotStartTime   String
  slotEndTime     String
  slotMinutes     Int           @default(15)
  slotCapacity    Int
  isPublished     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
}

model Reservation {
  id            Int       @id @default(autoincrement())
  pickupDayId   Int
  customerName  String
  mobile        String
  email         String?
  quantity      Int
  pickupTime    String
  status        String    @default("reserved")
  createdAt     DateTime  @default(now())

  pickupDay     PickupDay @relation(fields: [pickupDayId], references: [id])
}